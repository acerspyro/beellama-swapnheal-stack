# Copy this file to `.env` and fill in values as needed.
# docker-compose will load it automatically and pass values to the MCP Gateway.

# --- Tavily (Web Search) ---
TAVILY_API_KEY=

# --- DeepWiki (Deep research/crawling) ---
DEEPWIKI_API_KEY=

# --- FireCrawl (Broad crawl/structured extraction) ---
FIRECRAWL_API_KEY=
